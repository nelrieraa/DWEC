<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/css/style.css">
    <title>Biblioteca - Catálogo</title>
</head>
<body>
    <nav>
        <a href="/">Catálogo</a> | <a href="/prestados">Libros Prestados</a> | <a href="/vencidos">Vencidos</a>
    </nav>
    <h1>Catálogo de Libros</h1>
    <table border="1">
        <thead>
            <tr>
                <th>Título</th>
                <th>Autor</th>
                <th>Estado</th>
            </tr>
        </thead>
        <tbody>
            <% libros.forEach(libro => { %>
                <tr>
                    <td><a href="/libro/<%= libro.id %>"><%= libro.titulo %></a></td>
                    <td><%= libro.autor %></td>
                    <td class="<%= libro.estado.toLowerCase() %>"><%= libro.estado %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
</body>
</html>