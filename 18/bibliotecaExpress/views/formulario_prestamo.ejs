<!DOCTYPE html>
<html lang="es">
<head>
    <link rel="stylesheet" href="/css/style.css">
    <title>Nuevo Préstamo</title>
</head>
<body>
    <h1>Registrar Nuevo Préstamo</h1>
    <form action="/prestamo/nuevo" method="POST">
        <input type="hidden" name="libro_id" value="<%= libro_id %>">
        
        <label>Nombre del Prestatario:</label><br>
        <input type="text" name="nombre_prestatario" required><br><br>
        
        <label>Fecha de Devolución:</label><br>
        <input type="date" name="fecha_devolucion" required><br><br>
        
        <button type="submit">Confirmar Préstamo</button>
        <a href="/">Cancelar</a>
    </form>
</body>
</html>